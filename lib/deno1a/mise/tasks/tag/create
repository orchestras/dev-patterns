#!/usr/bin/env bash
#MISE description="Create a git tag from the current deno.json version (does not push)"
# Tags use bare semver format: 0.1.0 (no v-prefix).
set -euo pipefail
if [ ! -f "deno.json" ]; then
  echo "No deno.json found"
  exit 1
fi
tag=$(jq -r '.version // "0.1.0"' deno.json)
# Strip v-prefix if present (we use bare semver)
tag="${tag#v}"
git tag -l | grep -qx "${tag}" && { echo "Tag ${tag} already exists."; exit 0; }
git tag -a "${tag}" -m "${tag}"
echo "✓ Tag ${tag} created. Run 'mise run tag:push' to push."
