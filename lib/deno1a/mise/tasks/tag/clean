#!/usr/bin/env bash
#MISE description="Delete local semver tags that are not on the remote"
# Tags use bare semver format: 0.1.0 (no v-prefix).
set -euo pipefail

echo "Fetching remote tags..."
git fetch --tags origin
remote_tags=$(git ls-remote --tags origin 'refs/tags/[0-9]*' | awk '{print $2}' | sed 's|refs/tags/||' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+')
local_tags=$(git tag -l '[0-9]*.[0-9]*.[0-9]*' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+')

deleted=0
while IFS= read -r tag; do
  [ -z "$tag" ] && continue
  if ! echo "${remote_tags}" | grep -qxF "${tag}"; then
    git tag -d "${tag}"
    deleted=$((deleted + 1))
  fi
done <<< "${local_tags}"

echo "✓ Cleaned ${deleted} local tag(s) not on remote"
