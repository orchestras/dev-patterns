#!/usr/bin/env bash
#MISE description="Delete local semver tags that are not on the remote"
set -euo pipefail

remote_tags=$(git ls-remote --tags origin 'refs/tags/[0-9]*' | awk '{print $2}' | sed 's|refs/tags/||')
local_tags=$(git tag -l '[0-9]*.[0-9]*.[0-9]*')

deleted=0
while IFS= read -r tag; do
  if ! echo "${remote_tags}" | grep -qxF "${tag}"; then
    git tag -d "${tag}"
    deleted=$((deleted + 1))
  fi
done <<< "${local_tags}"

echo "✓ Cleaned ${deleted} local tag(s) not on remote"
