#!/usr/bin/env bash
#MISE description="Bump major version from latest remote tag (e.g. 0.1.5 → 1.0.0)"
# Tags use bare semver format: 0.1.0 (no v-prefix).
set -euo pipefail

git fetch --tags origin
latest=$(git tag -l '[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | head -n 1)
[ -z "$latest" ] && latest="0.0.0"

IFS='.' read -r major _minor _patch <<< "$latest"
new="$((major + 1)).0.0"

tmp=$(mktemp)
jq --arg v "${new}" '.version = $v' deno.json > "${tmp}" && mv "${tmp}" deno.json

if [ -f "src/make_version.ts" ]; then
  deno run --allow-read --allow-write src/make_version.ts
  git add deno.json src/version.ts
else
  git add deno.json
fi

git commit -m "chore: bump version ${latest} → ${new}"
git tag -l | grep -qx "${new}" || git tag -a "${new}" -m "${new}"

echo "✓ Bumped ${latest} → ${new}"
echo "  Push with: mise run tag:push"
