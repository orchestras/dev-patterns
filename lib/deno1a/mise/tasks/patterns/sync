#!/usr/bin/env bash
#MISE description="Sync tasks, hooks, and skel files from the patterns channel (dev-patterns repo)"
set -euo pipefail

# ── Terminal colours ──────────────────────────────────────────────────────────
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'
CHECK="✓"; ARROW="→"; SPIN="⟳"

ROOT="$(git rev-parse --show-toplevel)"
PATTERNS_REPO="${PATTERNS_REPO:-orchestras/dev-patterns}"
PATTERNS_CHANNEL="${PATTERNS_CHANNEL:-deno1a}"
HASH_FILE="${ROOT}/.patterns-hash"
CACHE_DIR="${ROOT}/.mise/.patterns-cache"

echo -e "${CYAN}${BOLD}Patterns Sync${RESET}"
echo -e "  ${BLUE}${ARROW}${RESET} Repo:    ${PATTERNS_REPO}"
echo -e "  ${BLUE}${ARROW}${RESET} Channel: ${PATTERNS_CHANNEL}"
echo ""

# ── Fetch latest commit hash ──────────────────────────────────────────────────
echo -e "  ${SPIN} Fetching latest commit hash…"
latest_hash=""
if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
  latest_hash=$(gh api "repos/${PATTERNS_REPO}/commits/main" \
    --jq '.sha' 2>/dev/null || echo "")
fi
if [ -z "${latest_hash}" ]; then
  latest_hash=$(curl -sSf \
    "https://api.github.com/repos/${PATTERNS_REPO}/commits/main" \
    2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['sha'])" \
    2>/dev/null || echo "")
fi
if [ -z "${latest_hash}" ]; then
  echo -e "  ${YELLOW}⚠  Could not fetch commit hash. Skipping sync.${RESET}"
  exit 0
fi

# ── Skip if already current ───────────────────────────────────────────────────
cached_hash=""
[ -f "${HASH_FILE}" ] && cached_hash=$(cat "${HASH_FILE}" | tr -d '[:space:]')
if [ "${cached_hash}" = "${latest_hash}" ]; then
  echo -e "  ${GREEN}${CHECK} Already current (${latest_hash:0:8})${RESET}"
  exit 0
fi

echo -e "  ${SPIN} Downloading channel tarball (${latest_hash:0:8})…"

mkdir -p "${CACHE_DIR}"

TARBALL="${CACHE_DIR}/patterns-${latest_hash:0:8}.tar.gz"
if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
  gh api "repos/${PATTERNS_REPO}/tarball/main" \
    --header "Accept: application/vnd.github+json" \
    > "${TARBALL}" 2>/dev/null || \
  curl -sSfL "https://github.com/${PATTERNS_REPO}/archive/main.tar.gz" \
    -o "${TARBALL}"
else
  curl -sSfL "https://github.com/${PATTERNS_REPO}/archive/main.tar.gz" \
    -o "${TARBALL}"
fi

# ── Extract ───────────────────────────────────────────────────────────────────
EXTRACT_DIR="${CACHE_DIR}/extracted-${latest_hash:0:8}"
rm -rf "${EXTRACT_DIR}"
mkdir -p "${EXTRACT_DIR}"
tar -xzf "${TARBALL}" -C "${EXTRACT_DIR}" --strip-components=1

CHANNEL_DIR="${EXTRACT_DIR}/lib/${PATTERNS_CHANNEL}"
if [ ! -d "${CHANNEL_DIR}" ]; then
  echo -e "  ${YELLOW}⚠  Channel directory not found: lib/${PATTERNS_CHANNEL}${RESET}"
  exit 1
fi

# ── Sync mise tasks ───────────────────────────────────────────────────────────
if [ -d "${CHANNEL_DIR}/mise/tasks" ]; then
  echo -e "  ${SPIN} Syncing mise tasks…"
  mkdir -p "${ROOT}/.mise/tasks"
  cp -r "${CHANNEL_DIR}/mise/tasks/." "${ROOT}/.mise/tasks/"
  find "${ROOT}/.mise/tasks" -type f -exec chmod +x {} \;
  echo -e "  ${GREEN}${CHECK} Tasks synced → .mise/tasks/${RESET}"
fi

# ── Sync git hooks ────────────────────────────────────────────────────────────
if [ -d "${CHANNEL_DIR}/hooks" ]; then
  echo -e "  ${SPIN} Syncing git hooks…"
  mkdir -p "${ROOT}/config/githooks/hooks"
  cp -r "${CHANNEL_DIR}/hooks/." "${ROOT}/config/githooks/hooks/"
  find "${ROOT}/config/githooks/hooks" -type f ! -name "*.toml" -exec chmod +x {} \;
  echo -e "  ${GREEN}${CHECK} Hooks synced → config/githooks/hooks/${RESET}"
fi

# ── Sync skel files (with Jinja interpolation) ────────────────────────────────
SKEL_DIR="${CHANNEL_DIR}/skel"
if [ -d "${SKEL_DIR}" ]; then
  echo -e "  ${SPIN} Syncing skel files…"

  # Load skel.vars from the subscriber's mise.toml
  declare -A SKEL_VARS
  if [ -f "${ROOT}/mise.toml" ]; then
    in_skel_vars=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^\[skel\.vars\] ]]; then
        in_skel_vars=true; continue
      fi
      if [[ "$in_skel_vars" = true ]]; then
        [[ "$line" =~ ^\[ ]] && break
        if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*=[[:space:]]*\"(.*)\"$ ]]; then
          SKEL_VARS["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
        fi
      fi
    done < "${ROOT}/mise.toml"
  fi

  # Also load channel-default vars (do not overwrite subscriber values)
  CHANNEL_MISE="${CHANNEL_DIR}/mise/mise.toml"
  if [ -f "${CHANNEL_MISE}" ]; then
    in_skel_vars=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^\[skel\.vars\] ]]; then
        in_skel_vars=true; continue
      fi
      if [[ "$in_skel_vars" = true ]]; then
        [[ "$line" =~ ^\[ ]] && break
        if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*=[[:space:]]*\"(.*)\"$ ]]; then
          key="${BASH_REMATCH[1]}"
          # Subscriber value takes precedence
          [[ -v SKEL_VARS["${key}"] ]] || SKEL_VARS["${key}"]="${BASH_REMATCH[2]}"
        fi
      fi
    done < "${CHANNEL_MISE}"
  fi

  # Interpolate {{ skel.key }} tokens in a file
  interpolate_file() {
    local src="$1"
    local content
    content=$(cat "${src}")
    for key in "${!SKEL_VARS[@]}"; do
      local val="${SKEL_VARS[$key]}"
      local escaped_val
      escaped_val=$(printf '%s\n' "${val}" | sed 's/[&/\]/\\&/g; s/$/\\n/' | tr -d '\n' | sed 's/\\n$//')
      content=$(echo "${content}" | sed "s|{{ skel\\.${key} }}|${escaped_val}|g")
    done
    if echo "${content}" | grep -q '{{ skel\.'; then
      remaining=$(echo "${content}" | grep -o '{{ skel\.[^}]* }}' | sort -u | tr '\n' ' ')
      echo -e "  ${YELLOW}⚠  Unresolved skel vars: ${remaining}${RESET}" >&2
    fi
    printf '%s' "${content}"
  }

  # Read skel file list from subscriber's mise.toml (or channel default)
  SKEL_FILES=()
  for toml_src in "${ROOT}/mise.toml" "${CHANNEL_MISE}"; do
    [ -f "${toml_src}" ] || continue
    in_skel=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^\[skel\] ]]; then in_skel=true; continue; fi
      if [[ "$in_skel" = true ]]; then
        [[ "$line" =~ ^\[ ]] && break
        if [[ "$line" =~ files && "$line" =~ \[ ]]; then continue; fi
        if [[ "$line" =~ \"([^\"]+)\" ]]; then
          SKEL_FILES+=("${BASH_REMATCH[1]}")
        fi
      fi
    done < "${toml_src}"
    [ ${#SKEL_FILES[@]} -gt 0 ] && break
  done

  synced_count=0
  for rel_path in "${SKEL_FILES[@]}"; do
    src="${SKEL_DIR}/${rel_path}"
    dst="${ROOT}/${rel_path}"
    [ ! -f "${src}" ] && continue
    mkdir -p "$(dirname "${dst}")"
    interpolate_file "${src}" > "${dst}"
    echo -e "  ${GREEN}${CHECK}${RESET} ${rel_path}"
    synced_count=$((synced_count + 1))
  done
  echo -e "  ${GREEN}${CHECK} Skel synced (${synced_count} file(s)) → project root${RESET}"
fi

# ── Sync any other top-level channel items (scripts, etc.) ───────────────────
for item in "${CHANNEL_DIR}"/*; do
  base=$(basename "${item}")
  [[ "${base}" == "mise" || "${base}" == "hooks" || "${base}" == "skel" ]] && continue
  dest="${ROOT}/${base}"
  if [ -d "${item}" ]; then
    mkdir -p "${dest}"
    cp -r "${item}/." "${dest}/"
  else
    cp "${item}" "${dest}"
  fi
  echo -e "  ${GREEN}${CHECK} Synced ${base}${RESET}"
done

# ── Write hash file ───────────────────────────────────────────────────────────
echo "${latest_hash}" > "${HASH_FILE}"

echo ""
echo -e "${GREEN}${BOLD}${CHECK} Patterns synced${RESET} (${PATTERNS_CHANNEL} @ ${latest_hash:0:8})"
