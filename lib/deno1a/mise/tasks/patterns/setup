#!/usr/bin/env bash
#MISE description="Interactive setup: subscribe to a patterns channel (prompts or CLI args)"
set -euo pipefail

# ── Terminal colours ──────────────────────────────────────────────────────────
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'
CHECK="✓"; ARROW="→"

ROOT="$(git rev-parse --show-toplevel)"
MISE_TOML="${ROOT}/mise.toml"

# ── CLI args or interactive prompt ────────────────────────────────────────────
# Usage: mise run patterns:setup [<repo> [<channel>]]
PATTERNS_REPO_ARG="${1:-}"
PATTERNS_CHANNEL_ARG="${2:-}"

echo -e "${CYAN}${BOLD}Patterns Setup${RESET}"
echo ""

# Repo
if [ -z "${PATTERNS_REPO_ARG}" ]; then
  DEFAULT_REPO="${PATTERNS_REPO:-orchestras/dev-patterns}"
  echo -e "  Patterns repository ${BLUE}[${DEFAULT_REPO}]${RESET}: \c"
  read -r input_repo
  PATTERNS_REPO_ARG="${input_repo:-${DEFAULT_REPO}}"
fi

# Channel selection
if [ -z "${PATTERNS_CHANNEL_ARG}" ]; then
  echo ""
  echo -e "  ${BLUE}Available channels:${RESET}"

  # Try to list channels from the repo
  channels=()
  if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
    mapfile -t channels < <(
      gh api "repos/${PATTERNS_REPO_ARG}/contents/lib" \
        --jq '.[].name' 2>/dev/null || true
    )
  fi
  if [ ${#channels[@]} -eq 0 ]; then
    channels=("python3a" "deno1a")
  fi

  for i in "${!channels[@]}"; do
    echo -e "    ${BOLD}$((i+1)).${RESET} ${channels[$i]}"
  done

  echo ""
  DEFAULT_CHANNEL="${PATTERNS_CHANNEL:-deno1a}"
  echo -e "  Channel ${BLUE}[${DEFAULT_CHANNEL}]${RESET}: \c"
  read -r input_channel
  PATTERNS_CHANNEL_ARG="${input_channel:-${DEFAULT_CHANNEL}}"
fi

echo ""
echo -e "  ${ARROW} Repo:    ${PATTERNS_REPO_ARG}"
echo -e "  ${ARROW} Channel: ${PATTERNS_CHANNEL_ARG}"
echo ""

# ── Write env vars to mise.toml ───────────────────────────────────────────────
if [ ! -f "${MISE_TOML}" ]; then
  echo "[env]" > "${MISE_TOML}"
fi

# Update or insert PATTERNS_REPO and PATTERNS_CHANNEL
python3 - "${MISE_TOML}" "${PATTERNS_REPO_ARG}" "${PATTERNS_CHANNEL_ARG}" <<'PYEOF'
import sys, re, pathlib

toml_path = pathlib.Path(sys.argv[1])
repo      = sys.argv[2]
channel   = sys.argv[3]
text      = toml_path.read_text()

def set_var(text: str, key: str, value: str) -> str:
    pattern = rf'^{key}\s*=.*$'
    replacement = f'{key} = "{value}"'
    if re.search(pattern, text, flags=re.MULTILINE):
        return re.sub(pattern, replacement, text, flags=re.MULTILINE)
    # Append under [env] section
    env_match = re.search(r'^\[env\]', text, flags=re.MULTILINE)
    if env_match:
        insert_pos = env_match.end()
        return text[:insert_pos] + f'\n{replacement}' + text[insert_pos:]
    return text + f'\n[env]\n{replacement}\n'

text = set_var(text, 'PATTERNS_REPO',    repo)
text = set_var(text, 'PATTERNS_CHANNEL', channel)
toml_path.write_text(text)
print(f'  Updated mise.toml: PATTERNS_REPO={repo}, PATTERNS_CHANNEL={channel}')
PYEOF

echo -e "  ${GREEN}${CHECK} mise.toml updated${RESET}"

# ── Install bootstrap sync script if not present ─────────────────────────────
if [ ! -f "${ROOT}/scripts/sync_patterns.sh" ]; then
  echo -e "  ${ARROW} Downloading bootstrap script…"
  if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
    gh api "repos/${PATTERNS_REPO_ARG}/contents/scripts/sync_patterns.sh" \
      --jq '.content' | base64 -d > "${ROOT}/scripts/sync_patterns.sh" 2>/dev/null || true
  fi
  if [ ! -s "${ROOT}/scripts/sync_patterns.sh" ]; then
    curl -sSfL \
      "https://raw.githubusercontent.com/${PATTERNS_REPO_ARG}/main/scripts/sync_patterns.sh" \
      -o "${ROOT}/scripts/sync_patterns.sh" 2>/dev/null || true
  fi
  if [ -f "${ROOT}/scripts/sync_patterns.sh" ]; then
    chmod +x "${ROOT}/scripts/sync_patterns.sh"
    echo -e "  ${GREEN}${CHECK} sync_patterns.sh downloaded${RESET}"
  fi
fi

# ── Run initial sync ──────────────────────────────────────────────────────────
echo ""
echo -e "  ${ARROW} Running initial sync…"
PATTERNS_REPO="${PATTERNS_REPO_ARG}" PATTERNS_CHANNEL="${PATTERNS_CHANNEL_ARG}" \
  mise run patterns:sync

echo ""
echo -e "${GREEN}${BOLD}${CHECK} Setup complete${RESET}"
echo -e "  Run ${BOLD}mise run patterns:sync${RESET} at any time to pull the latest patterns."
