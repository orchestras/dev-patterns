#!/usr/bin/env bash
#MISE description="Create initial 0.1.0 tag if no version tags exist on remote"
set -euo pipefail

git fetch --tags origin

remote_tags=$(git ls-remote --tags origin 'refs/tags/[0-9]*' 2>/dev/null | wc -l | tr -d ' ')
if [ "$remote_tags" -gt 0 ]; then
  latest=$(git tag -l '[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -v '+' | head -n 1)
  echo "Tags exist on remote (latest: ${latest}). Skipping init."
  exit 0
fi

git tag -a 0.1.0 -m "0.1.0 — initial version"
git push origin 0.1.0
echo "✓ Created and pushed initial tag 0.1.0"
