#!/usr/bin/env bash
#MISE description="Create initial 0.1.0 tag if no semver tags exist on remote"
# Tags use bare semver format: 0.1.0 (no v-prefix).
set -euo pipefail

git fetch --tags origin
remote_count=$(git ls-remote --tags origin 'refs/tags/[0-9]*' 2>/dev/null | grep -E 'refs/tags/[0-9]+\.[0-9]+\.[0-9]+$' | wc -l | tr -d ' ')

if [ "${remote_count}" -gt 0 ]; then
  latest=$(git tag -l '[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | head -n 1)
  echo "Remote has ${remote_count} tags (latest: ${latest}). Skipping init."
  exit 0
fi

git tag -a 0.1.0 -m "0.1.0 — initial version"
git push origin 0.1.0
echo "✓ Created and pushed initial tag 0.1.0"
